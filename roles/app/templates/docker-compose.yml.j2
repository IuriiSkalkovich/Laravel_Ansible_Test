services:
  nginx:
    image: nginx:{{ nginx_version }}
    container_name: nginx
    restart: always
    ports:
      - "{{ nginx_port }}:80"
    volumes:
      - ./src:/var/www/html # Монтируем исходный код Laravel
      - ./default.conf:/etc/nginx/conf.d/default.conf # Прокидываем конфиг хоста
    depends_on:
      app:
        condition: service_started # Ждем запуск контейнера app

  app:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: app
    restart: unless-stopped
    volumes:
      - ./src:/var/www/html # Монтирем код Laravel
    depends_on:
      mysql:
        condition: service_healthy # Ждем полной готовности MySQL

  mysql:
    image: mysql:{{ mysql_version }}
    container_name: mysql
    environment:
      MYSQL_DATABASE: {{ mysql_database }}
      MYSQL_USER: {{ mysql_user }}
      MYSQL_PASSWORD: {{ mysql_password }}
      MYSQL_ROOT_PASSWORD: {{ mysql_root_password }}
    volumes:
      - mysql_data:/var/lib/mysql # Изолированный volume для хранения данных БД
    ports:
      - "127.0.0.1:3306:3306"
    healthcheck: # Проверка готовности БД (чтобы Laravel не упал при старте)
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost"]
      interval: 5s
      timeout: 3s
      retries: 5

  phpmyadmin:
    image: phpmyadmin:{{ phpmyadmin_version }}
    container_name: phpmyadmin
    environment:
      PMA_HOST: mysql
      PMA_ABSOLUTE_URI: http://localhost/pma/
    depends_on:
      mysql:
        condition: service_healthy # Запуск только после готовности БД

volumes:
  mysql_data: # Объявление  volume для MySQL
    driver: local
